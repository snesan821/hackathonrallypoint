# RallyPoint Environment Variables
# Copy this file to .env.local and fill in the values

# ==================================
# Node Environment
# ==================================
NODE_ENV=development

# ==================================
# Database
# ==================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/rallypoint"

# ==================================
# Redis
# ==================================
# Redis connection string for caching and rate limiting
# Format: redis://HOST:PORT or redis://USER:PASSWORD@HOST:PORT
REDIS_URL="redis://localhost:6379"

# ==================================
# Clerk Authentication
# ==================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Webhook secret for Clerk user sync (found in Clerk Dashboard > Webhooks)
CLERK_WEBHOOK_SECRET="whsec_..."

# ==================================
# Anthropic (Claude AI)
# ==================================
# Get API key from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ==================================
# Application URLs
# ==================================
# Public URL of your application
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ==================================
# Security
# ==================================
# Random 32+ character string for IP hashing
# Generate with: openssl rand -base64 32
SECURITY_SALT="your-random-32-character-string-here"

# ==================================
# Rate Limiting (Optional)
# ==================================
# Override default rate limits
RATE_LIMIT_COMMENTS_PER_HOUR=10
RATE_LIMIT_ENGAGEMENTS_PER_MINUTE=30

# ==================================
# Geocoding (Optional - for production)
# ==================================
# Google Maps API key for geocoding
# Get from https://console.cloud.google.com
# GOOGLE_MAPS_API_KEY=""

# Or use Nominatim (free, open source)
# NOMINATIM_API_URL="https://nominatim.openstreetmap.org"

# Mapbox for map visualization (optional)
# NEXT_PUBLIC_MAPBOX_TOKEN=""

# ==================================
# Analytics (Optional)
# ==================================
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_ID=""

# Sentry for error tracking
# SENTRY_DSN=""

# ==================================
# Feature Flags
# ==================================
# Enable/disable features
ENABLE_AI_SUMMARIES=true
ENABLE_MODERATION=true
ENABLE_FRAUD_DETECTION=true

# ==================================
# Development Only
# ==================================
# Skip environment validation (not recommended)
# SKIP_ENV_VALIDATION=false
